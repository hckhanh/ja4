{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices", ":pinOnlyDevDependencies", ":separateMultipleMajorReleases"],
  "timezone": "Asia/Ho_Chi_Minh",
  "schedule": ["* 0-5 * * 1-5"],
  "automergeSchedule": ["* 9-15 * * 1-5"],
  "prConcurrentLimit": 5,
  "postUpdateOptions": ["pnpmDedupe"],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "Automerge non-major dev dependency updates",
      "matchManagers": ["npm"],
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch", "digest", "pin"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Group non-major dev dependency updates into a single PR",
      "matchManagers": ["npm"],
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch", "digest", "pin"],
      "groupName": "non-major dev dependencies",
      "groupSlug": "non-major-dev-deps"
    },
    {
      "description": "Group GitHub Actions non-major updates",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest", "pinDigest"],
      "groupName": "GitHub Actions",
      "groupSlug": "github-actions",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Group TypeScript-related major updates together",
      "matchPackageNames": ["typescript", "@typescript/native-preview"],
      "matchUpdateTypes": ["major"],
      "groupName": "TypeScript major",
      "groupSlug": "typescript-major"
    }
  ]
}
